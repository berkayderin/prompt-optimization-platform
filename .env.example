# LLM saglayici ayarlari. Bu dosyayi `.env` olarak kopyalayin ve doldurun.
# Saglayici secimi: mock | deepseek | glm | openai | ollama
# mock: anahtar gerekmez, tum akisi test etmek icin sahte yanit uretir.
LLM_PROVIDER=mock

# --- DeepSeek (https://platform.deepseek.com) ---
DEEPSEEK_API_KEY=
# Modeller: deepseek-chat (V3) | deepseek-reasoner (R1)
DEEPSEEK_MODEL=deepseek-chat

# --- GLM / Zhipu (https://bigmodel.cn) ---
GLM_API_KEY=
# Modeller: glm-4-flash (ucuz) | glm-4-plus
GLM_MODEL=glm-4-flash

# --- OpenAI (opsiyonel, kiyas icin) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (yerel, anahtarsiz) ---
OLLAMA_MODEL=llama3
